#include <stdio.h>

int main() {
    int num, sum;

    printf("Enter a number: ");
    scanf("%d", &num);

    while (num >= 10) {   // repeat until single digit
        sum = 0;

        while (num > 0) {
            sum = sum + (num % 10);
            num = num / 10;
        }

        num = sum;  // update number with sum
    }

    printf("Single digit result: %d", num);

    return 0;
}
